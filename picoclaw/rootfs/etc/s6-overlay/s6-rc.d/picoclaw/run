#!/command/with-contenv bashio
# shellcheck shell=bash
set -e

# ── Paths ─────────────────────────────────────────────────────────────────────
export HOME="/share/picoclaw"
CONFIG_FILE="${HOME}/.picoclaw/config.json"
mkdir -p "${HOME}/.picoclaw"

# ── Read options ──────────────────────────────────────────────────────────────
PROVIDER=$(bashio::config 'provider')
API_KEY=$(bashio::config 'api_key')
MODEL=$(bashio::config 'model')
TIMEZONE=$(bashio::config 'timezone')
TOKEN=$(bashio::config 'telegram_token')
ALLOWED=$(bashio::config 'telegram_allowed_users')

# ── Validate required options ─────────────────────────────────────────────────
if bashio::var.is_empty "${API_KEY}"; then
    bashio::log.fatal "API key is required. Set it in the add-on configuration."
    exit 1
fi

# ── Timezone ──────────────────────────────────────────────────────────────────
if [ -f "/usr/share/zoneinfo/${TIMEZONE}" ]; then
    ln -sf "/usr/share/zoneinfo/${TIMEZONE}" /etc/localtime
    echo "${TIMEZONE}" > /etc/timezone
    export TZ="${TIMEZONE}"
    bashio::log.info "Timezone set to ${TIMEZONE}"
else
    bashio::log.warning "Unknown timezone '${TIMEZONE}', falling back to UTC."
fi

# ── Export API key env vars ───────────────────────────────────────────────────
export PICOCLAW_API_KEY="${API_KEY}"
case "${PROVIDER}" in
    gemini|google)    export GEMINI_API_KEY="${API_KEY}" ;;
    openai)           export OPENAI_API_KEY="${API_KEY}" ;;
    anthropic)        export ANTHROPIC_API_KEY="${API_KEY}" ;;
    openrouter)       export OPENROUTER_API_KEY="${API_KEY}" ;;
    mistral)          export MISTRAL_API_KEY="${API_KEY}" ;;
    groq)             export GROQ_API_KEY="${API_KEY}" ;;
    deepseek)         export DEEPSEEK_API_KEY="${API_KEY}" ;;
    xai)              export XAI_API_KEY="${API_KEY}" ;;
esac

# ── Telegram env var ──────────────────────────────────────────────────────────
if [ -n "${TOKEN}" ]; then
    export TELEGRAM_BOT_TOKEN="${TOKEN}"
fi

# ── First-run: bootstrap config via picoclaw onboard ─────────────────────────
if [ ! -f "${CONFIG_FILE}" ]; then
    bashio::log.info "First start detected — running initial setup..."
    /usr/local/bin/picoclaw onboard 2>/dev/null || true
    bashio::log.info "Setup complete."
fi

# ── Patch config.json with HA UI options ─────────────────────────────────────
# Build allowed_from array for telegram: "*" → [] (allow all), else split CSV
if [ "${ALLOWED}" = "*" ]; then
    ALLOWED_JSON="[]"
else
    ALLOWED_JSON="[$(echo "${ALLOWED}" | sed 's/,/","/g; s/^/"/; s/$/"/' )]"
fi

TELEGRAM_ENABLED="false"
if [ -n "${TOKEN}" ]; then TELEGRAM_ENABLED="true"; fi

jq --arg provider    "${PROVIDER}" \
   --arg model       "${MODEL}" \
   --argjson tg_on   "${TELEGRAM_ENABLED}" \
   --argjson allowed "${ALLOWED_JSON}" \
   '
   .agents.defaults.provider    = $provider |
   .agents.defaults.model_name  = $model |
   .gateway.host                = "0.0.0.0" |
   .gateway.log_level           = "info" |
   .channels.pico.enabled       = true |
   .channels.pico.host          = "0.0.0.0" |
   .channels.pico.port          = 18790 |
   .channels.telegram.enabled   = $tg_on |
   .channels.telegram.allow_from = $allowed
   ' "${CONFIG_FILE}" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "${CONFIG_FILE}"

bashio::log.info "Config patched (provider=${PROVIDER}, model=${MODEL}, telegram=${TELEGRAM_ENABLED})."

# ── Start gateway ─────────────────────────────────────────────────────────────
bashio::log.info "Starting PicoClaw gateway (provider=${PROVIDER}, model=${MODEL})..."
exec /usr/local/bin/picoclaw gateway 2>&1
