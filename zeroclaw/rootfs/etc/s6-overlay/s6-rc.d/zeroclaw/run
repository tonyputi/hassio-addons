#!/command/with-contenv bashio
# shellcheck shell=bash
set -e

# ── Paths ────────────────────────────────────────────────────────────────────
export HOME="/share/zeroclaw"
export SHELL="/bin/bash"

ZEROCLAW_DATA="/share/zeroclaw/.zeroclaw"
CONFIG_FILE="${ZEROCLAW_DATA}/config.toml"
mkdir -p "${ZEROCLAW_DATA}" "${HOME}/workspace"

# Redirect ZeroClaw's default internal data dir to the persistent share volume.
# v0.6.8+ uses /usr/local/var/zeroclaw/ instead of ~/.zeroclaw/ — symlink it.
mkdir -p /usr/local/var
ln -sfn "${ZEROCLAW_DATA}" /usr/local/var/zeroclaw

# ── Inject environment variables from HA UI configuration ────────────────────
for index in $(bashio::config 'env_vars|keys[]' 2>/dev/null || true); do
    name=$(bashio::config "env_vars[${index}].name")
    value=$(bashio::config "env_vars[${index}].value")
    [ -z "${name}" ] && continue
    export "${name}=${value}"
    printf '%s' "${value}" > "/var/run/s6/container_environment/${name}" 2>/dev/null || true
    bashio::log.info "Env var set: ${name}"
done

# ── First-run guard ───────────────────────────────────────────────────────────
if [ ! -f "${CONFIG_FILE}" ]; then
    bashio::log.fatal "No configuration found. Open the web terminal and run: zeroclaw onboard"
    exit 1
fi

# ── One-time config V2 migration (0.7.0+) ─────────────────────────────────────
MIGRATED_MARKER="${ZEROCLAW_DATA}/.v2_migrated"
if [ ! -f "${MIGRATED_MARKER}" ]; then
    bashio::log.info "Running one-time config migration to V2..."
    if /usr/local/bin/zeroclaw config migrate 2>&1; then
        touch "${MIGRATED_MARKER}"
        bashio::log.info "Config migration to V2 completed."
    else
        bashio::log.warning "Config migration failed — continuing with existing config."
        touch "${MIGRATED_MARKER}"
    fi
fi

# ── Read options ──────────────────────────────────────────────────────────────
TIMEZONE=$(bashio::config 'timezone')

# ── Timezone ──────────────────────────────────────────────────────────────────
if [ -f "/usr/share/zoneinfo/${TIMEZONE}" ]; then
    ln -sf "/usr/share/zoneinfo/${TIMEZONE}" /etc/localtime
    echo "${TIMEZONE}" > /etc/timezone
    bashio::log.info "Timezone set to ${TIMEZONE}"
else
    bashio::log.warning "Unknown timezone '${TIMEZONE}', falling back to UTC."
fi

# ── V2 compat: remove inline "servers = [...]" from [mcp] section ────────────
# ZeroClaw 0.7.x may rewrite [[mcp.servers]] as inline arrays; we always use the
# array-of-tables form so we strip any inline definition to avoid duplicate keys.
sed -i '/^\[mcp\]/,/^\[/{/^servers = \[/d}' "${CONFIG_FILE}"

# ── Remove only the managed home-assistant MCP block before re-injection ───────
# Uses awk to surgically remove the [[mcp.servers]] block with name = "home-assistant"
# while leaving all user-defined [[mcp.servers]] entries untouched.
MCP_HA="${ZEROCLAW_DATA}/mcp-ha.toml"
awk '
BEGIN { in_block=0; ha_block=0; block_buf="" }
/^\[/ {
    if (block_buf != "" && !ha_block) printf "%s", block_buf
    block_buf = ""; ha_block = 0
    if (/^\[\[mcp\.servers\]\]/) { in_block=1; block_buf=$0 "\n" }
    else { in_block=0; print }
    next
}
in_block { block_buf=block_buf $0 "\n"; if (/^name = "home-assistant"/) ha_block=1; next }
{ print }
END { if (block_buf != "" && !ha_block) printf "%s", block_buf }
' "${CONFIG_FILE}" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "${CONFIG_FILE}"

# ── Home Assistant MCP integration ────────────────────────────────────────────
HA_MCP_ENABLED=$(bashio::config 'ha_mcp_enabled')
if bashio::var.true "${HA_MCP_ENABLED}"; then
    if grep -q '^\[mcp\]' "${CONFIG_FILE}" 2>/dev/null; then
        sed -i '/^\[mcp\]/,/^\[/{s/^enabled = false$/enabled = true/}' "${CONFIG_FILE}"
        sed -i '/^\[mcp\]/,/^\[/{s/^deferred_loading = true$/deferred_loading = false/}' "${CONFIG_FILE}"
        sed -i '/^servers = \[\]$/d' "${CONFIG_FILE}"
        bashio::log.info "MCP section updated: enabled = true, deferred_loading = false."
    else
        cat >> "${CONFIG_FILE}" <<EOF

[mcp]
enabled = true
deferred_loading = false
EOF
    fi

    if grep -q '^\[autonomy\]' "${CONFIG_FILE}" 2>/dev/null; then
        sed -i '/^\[autonomy\]/,/^\[/{s/^level = "supervised"$/level = "full"/}' "${CONFIG_FILE}"
        sed -i '/^\[autonomy\]/,/^\[/{s/^require_approval_for_medium_risk = true$/require_approval_for_medium_risk = false/}' "${CONFIG_FILE}"
    fi

    HA_TOKEN="${SUPERVISOR_TOKEN}"
    cat > "${MCP_HA}" <<EOF

[[mcp.servers]]
name = "home-assistant"
transport = "http"
url = "http://supervisor/core/api/mcp"
headers = { Authorization = "Bearer ${HA_TOKEN}" }
EOF
    cat "${MCP_HA}" >> "${CONFIG_FILE}"
    bashio::log.info "Home Assistant MCP server configured."
else
    rm -f "${MCP_HA}"
fi

# ── Gateway: bind to 0.0.0.0 for direct port access ──────────────────────────
GATEWAY_PAIRING=$(bashio::config 'gateway_pairing')
PAIRING_VAL="true"
if bashio::var.false "${GATEWAY_PAIRING}"; then PAIRING_VAL="false"; fi

if grep -q '^\[gateway\]' "${CONFIG_FILE}" 2>/dev/null; then
    sed -i '/^\[gateway\]/,/^\[/{s/^host = ".*"/host = "0.0.0.0"/}' "${CONFIG_FILE}"
    sed -i '/^\[gateway\]/,/^\[/{s/^port = .*/port = 42617/}' "${CONFIG_FILE}"
    sed -i '/^\[gateway\]/,/^\[/{s/^allow_public_bind = .*$/allow_public_bind = true/}' "${CONFIG_FILE}"
    sed -i '/^\[gateway\]/,/^\[/{s/^require_pairing = .*$/require_pairing = '"${PAIRING_VAL}"'/}' "${CONFIG_FILE}"
else
    cat >> "${CONFIG_FILE}" <<EOF

[gateway]
host = "0.0.0.0"
port = 42617
allow_public_bind = true
require_pairing = ${PAIRING_VAL}
EOF
fi
bashio::log.info "Gateway configured (port=42617, pairing=${PAIRING_VAL})."

# ── Browser addon auto-detect ─────────────────────────────────────────────────
BROWSER_CDP_PORT=$(bashio::config 'browser_cdp_port')
HOST_IP=""
if command -v ip > /dev/null 2>&1; then
    HOST_IP=$(ip route show default 2>/dev/null | awk '/default/ {print $3; exit}') || true
fi
if [ -z "${HOST_IP}" ]; then HOST_IP="172.30.32.1"; fi
BROWSER_CDP_URL="ws://${HOST_IP}:${BROWSER_CDP_PORT}"
BROWSER_DETECTED=false
for i in 1 2 3 4 5 6; do
    if curl -sf "http://${HOST_IP}:${BROWSER_CDP_PORT}/json/version" > /dev/null 2>&1; then
        BROWSER_DETECTED=true
        break
    fi
    if [ "${i}" -lt 6 ]; then bashio::log.info "Waiting for browser addon... (${i}/6)"; sleep 5; fi
done
if [ "${BROWSER_DETECTED}" = "true" ]; then
    bashio::log.info "Browser addon detected — configuring agent-browser CDP at ${BROWSER_CDP_URL}"
    mkdir -p "${HOME}/.agent-browser"
    printf '{"cdp":"%s"}\n' "${BROWSER_CDP_URL}" > "${HOME}/.agent-browser/config.json"
else
    bashio::log.info "No browser addon detected — browser tools unavailable. Install browserless_chrome addon to enable."
fi

# ── Start daemon ──────────────────────────────────────────────────────────────
bashio::log.info "Starting ZeroClaw daemon..."
exec /usr/local/bin/zeroclaw daemon
