#!/command/with-contenv bashio
# shellcheck shell=bash
set -e

# ── Paths ────────────────────────────────────────────────────────────────────
export HOME="/share/zeroclaw"
export SHELL="/bin/bash"

ZEROCLAW_DATA="/share/zeroclaw/.zeroclaw"
CONFIG_FILE="${ZEROCLAW_DATA}/config.toml"
# v0.8.0+ resolves the install root from ZEROCLAW_CONFIG_DIR (priority 1) —
# explicit beats relying on HOME/legacy fallbacks. Pre-create the V3 layout:
# data/ (shared DBs), shared/skills/ (host-wide skills), and the per-agent
# workspace for the implicit "default" agent created by V2→V3 migration.
export ZEROCLAW_CONFIG_DIR="${ZEROCLAW_DATA}"
mkdir -p \
    "${ZEROCLAW_DATA}/data" \
    "${ZEROCLAW_DATA}/shared/skills" \
    "${ZEROCLAW_DATA}/agents/default/workspace"

# ── Inject environment variables from HA UI configuration ────────────────────
# Source via jq from /data/options.json (single source of truth, deduped).
if [ -f /data/options.json ]; then
    while IFS='=' read -r _name _value; do
        [ -z "${_name}" ] && continue
        export "${_name}=${_value}"
        printf '%s' "${_value}" > "/var/run/s6/container_environment/${_name}" 2>/dev/null || true
        bashio::log.info "Env var set: ${_name}"
    done < <(jq -r '(.env_vars // []) | map(select(.name != null and .name != "")) | unique_by(.name) | .[] | "\(.name)=\(.value)"' /data/options.json)
fi

# ── Write env vars to workspace so agents can read them via file_read ─────────
# (shell tool cannot access env vars under workspace_only security policy)
# Build via jq from /data/options.json — single source of truth, no bashio loop
# (bashio::config iteration was observed duplicating entries 32x at runtime).
# V3 splits the workspace per agent: write under the default agent's workspace,
# which is where the V2→V3 filesystem migration moves the legacy workspace/.
WORKSPACE_CONFIG="${ZEROCLAW_DATA}/agents/default/workspace/config"
mkdir -p "${WORKSPACE_CONFIG}"
ENV_VARS_FILE="${WORKSPACE_CONFIG}/env_vars.conf"
if [ -f /data/options.json ]; then
    jq -r '(.env_vars // []) | map(select(.name != null and .name != "")) | unique_by(.name) | .[] | "\(.name)=\(.value)"' \
        /data/options.json > "${ENV_VARS_FILE}.tmp" && \
        mv "${ENV_VARS_FILE}.tmp" "${ENV_VARS_FILE}"
else
    : > "${ENV_VARS_FILE}"
fi
chmod 600 "${ENV_VARS_FILE}"

# ── First-run guard ───────────────────────────────────────────────────────────
if [ ! -f "${CONFIG_FILE}" ]; then
    bashio::log.fatal "No configuration found. Open the web terminal and run: zeroclaw onboard"
    exit 1
fi

# ── One-time config V3 migration (0.8.0+) ─────────────────────────────────────
# V3 daemons auto-migrate in memory on every boot but leave config.toml on disk
# stale until `zeroclaw config migrate` commits the change. Run it once per
# install so the on-disk file is locked at schema_version = 3 and downstream
# tooling that reads the TOML sees the canonical V3 shape. Idempotent.
MIGRATED_MARKER="${ZEROCLAW_DATA}/.v3_migrated"
if [ ! -f "${MIGRATED_MARKER}" ]; then
    bashio::log.info "Running one-time config migration to V3..."
    if /usr/local/bin/zeroclaw config migrate 2>&1; then
        touch "${MIGRATED_MARKER}"
        bashio::log.info "Config migration to V3 completed."
    else
        bashio::log.warning "Config migration failed — continuing with existing config."
        touch "${MIGRATED_MARKER}"
    fi
fi

# ── Read options ──────────────────────────────────────────────────────────────
TIMEZONE=$(bashio::config 'timezone')

# ── Timezone ──────────────────────────────────────────────────────────────────
if [ -f "/usr/share/zoneinfo/${TIMEZONE}" ]; then
    ln -sf "/usr/share/zoneinfo/${TIMEZONE}" /etc/localtime
    echo "${TIMEZONE}" > /etc/timezone
    bashio::log.info "Timezone set to ${TIMEZONE}"
else
    bashio::log.warning "Unknown timezone '${TIMEZONE}', falling back to UTC."
fi

# ── Strip every managed/broken home-assistant MCP block before re-injection ───
# We must handle three shapes that may all coexist on upgraded installs:
#   1. V2 array-of-tables:  [[mcp.servers]] with name = "home-assistant"
#   2. V3 dotted form:      [mcp.servers.home-assistant] (+ sub-tables)
#   3. V3 migrator orphan:  [mcp.servers.headers] left over when the buggy
#      V2→V3 migration drops name/transport/url and only emits the headers
#      sub-table (see issue #16).
# A single awk pass buffers each section header + its body and only emits it
# if it does NOT match one of the three drop patterns. User-defined MCP
# servers under [mcp.servers.<other>] or [[mcp.servers]] with a different
# name are preserved.
MCP_HA="${ZEROCLAW_DATA}/mcp-ha.toml"
awk '
function flush_block() {
    if (block_buf != "" && !drop_block) printf "%s", block_buf
    block_buf = ""; drop_block = 0
}
BEGIN { block_buf = ""; drop_block = 0; in_aot = 0 }
/^\[/ {
    flush_block()
    block_buf = $0 "\n"
    in_aot = 0
    if ($0 == "[mcp.servers.headers]") { drop_block = 1; next }
    if ($0 ~ /^\[mcp\.servers\.home-assistant(\..*)?\]$/) { drop_block = 1; next }
    if ($0 == "[[mcp.servers]]") { in_aot = 1; next }
    next
}
in_aot && /^name = "home-assistant"$/ { drop_block = 1 }
{ block_buf = block_buf $0 "\n" }
END { flush_block() }
' "${CONFIG_FILE}" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "${CONFIG_FILE}"

# ── Home Assistant MCP integration ────────────────────────────────────────────
HA_MCP_ENABLED=$(bashio::config 'ha_mcp_enabled')
if bashio::var.true "${HA_MCP_ENABLED}"; then
    if grep -q '^\[mcp\]' "${CONFIG_FILE}" 2>/dev/null; then
        sed -i '/^\[mcp\]/,/^\[/{s/^enabled = false$/enabled = true/}' "${CONFIG_FILE}"
        sed -i '/^\[mcp\]/,/^\[/{s/^deferred_loading = true$/deferred_loading = false/}' "${CONFIG_FILE}"
        bashio::log.info "MCP section updated: enabled = true, deferred_loading = false."
    else
        cat >> "${CONFIG_FILE}" <<EOF

[mcp]
enabled = true
deferred_loading = false
EOF
    fi

    # Inject HA MCP server in V3-native dotted form. [[mcp.servers]] (array of
    # tables) would conflict with any dotted sub-table the migrator may have
    # left under mcp.servers.* and produces a duplicate-key TOML parse error.
    HA_TOKEN="${SUPERVISOR_TOKEN}"
    cat > "${MCP_HA}" <<EOF

[mcp.servers.home-assistant]
transport = "http"
url = "http://supervisor/core/api/mcp"

[mcp.servers.home-assistant.headers]
Authorization = "Bearer ${HA_TOKEN}"
EOF
    cat "${MCP_HA}" >> "${CONFIG_FILE}"
    bashio::log.info "Home Assistant MCP server configured (V3 dotted form)."
else
    rm -f "${MCP_HA}"
fi

# ── Gateway: bind to 0.0.0.0 for direct port access ──────────────────────────
GATEWAY_PAIRING=$(bashio::config 'gateway_pairing')
PAIRING_VAL="true"
if bashio::var.false "${GATEWAY_PAIRING}"; then PAIRING_VAL="false"; fi

WEB_DIST_DIR="/opt/zeroclaw/web/dist"
if grep -q '^\[gateway\]' "${CONFIG_FILE}" 2>/dev/null; then
    sed -i '/^\[gateway\]/,/^\[/{s/^host = ".*"/host = "0.0.0.0"/}' "${CONFIG_FILE}"
    sed -i '/^\[gateway\]/,/^\[/{s/^port = .*/port = 42617/}' "${CONFIG_FILE}"
    sed -i '/^\[gateway\]/,/^\[/{s/^allow_public_bind = .*$/allow_public_bind = true/}' "${CONFIG_FILE}"
    sed -i '/^\[gateway\]/,/^\[/{s/^require_pairing = .*$/require_pairing = '"${PAIRING_VAL}"'/}' "${CONFIG_FILE}"
    if awk '/^\[gateway\]/{f=1;next} /^\[/{f=0} f' "${CONFIG_FILE}" | grep -q '^web_dist_dir = '; then
        sed -i '/^\[gateway\]/,/^\[/{s|^web_dist_dir = .*|web_dist_dir = "'"${WEB_DIST_DIR}"'"|}' "${CONFIG_FILE}"
    else
        sed -i '/^\[gateway\]/a web_dist_dir = "'"${WEB_DIST_DIR}"'"' "${CONFIG_FILE}"
    fi
else
    cat >> "${CONFIG_FILE}" <<EOF

[gateway]
host = "0.0.0.0"
port = 42617
allow_public_bind = true
require_pairing = ${PAIRING_VAL}
web_dist_dir = "${WEB_DIST_DIR}"
EOF
fi
bashio::log.info "Gateway configured (port=42617, pairing=${PAIRING_VAL}, web_dist_dir=${WEB_DIST_DIR})."

# ── Browser addon auto-detect ─────────────────────────────────────────────────
BROWSER_CDP_PORT=$(bashio::config 'browser_cdp_port')
HOST_IP=""
if command -v ip > /dev/null 2>&1; then
    HOST_IP=$(ip route show default 2>/dev/null | awk '/default/ {print $3; exit}') || true
fi
if [ -z "${HOST_IP}" ]; then HOST_IP="172.30.32.1"; fi
BROWSER_CDP_URL="ws://${HOST_IP}:${BROWSER_CDP_PORT}"
BROWSER_DETECTED=false
for i in 1 2 3 4 5 6; do
    if curl -sf -o /dev/null --max-time 3 "http://${HOST_IP}:${BROWSER_CDP_PORT}/sessions" \
        || curl -sf -o /dev/null --max-time 3 "http://${HOST_IP}:${BROWSER_CDP_PORT}/json/version"; then
        BROWSER_DETECTED=true
        break
    fi
    if [ "${i}" -lt 6 ]; then bashio::log.info "Waiting for browser addon... (${i}/6)"; sleep 5; fi
done
if [ "${BROWSER_DETECTED}" = "true" ]; then
    bashio::log.info "Browser addon detected — configuring agent-browser CDP at ${BROWSER_CDP_URL}"
    mkdir -p "${HOME}/.agent-browser"
    printf '{"cdp":"%s"}\n' "${BROWSER_CDP_URL}" > "${HOME}/.agent-browser/config.json"
else
    bashio::log.info "No browser addon detected — browser tools unavailable. Install browserless_chrome addon to enable."
fi

# ── Start daemon ──────────────────────────────────────────────────────────────
bashio::log.info "Starting ZeroClaw daemon..."
exec /usr/local/bin/zeroclaw daemon
